From 9b325212971509649b1112597b3d425f3b655195 Mon Sep 17 00:00:00 2001
From: Savkin Nikita <50752617+N3WC0DER@users.noreply.github.com>
Date: Sun, 12 Jul 2026 16:11:46 +0400
Subject: [PATCH 4/4] Refactor (#3)

* refactor code

* fix read tags from master branch
---
 .github/workflows/ci.yml | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/.github/workflows/ci.yml b/.github/workflows/ci.yml
index cf66533..c44839d 100644
--- a/.github/workflows/ci.yml
+++ b/.github/workflows/ci.yml
@@ -82,7 +82,7 @@ jobs:
           echo "is_prerelease=true" >> $GITHUB_OUTPUT
         else
           # Если это мердж в master, ищем последний rc-тег, убираем из него "-rc.*"
-          LAST_RC_TAG=$(git describe --tags --abbrev=0 --match "v*.*.*-rc.*" 2>/dev/null || echo "v1.0.0-rc.1")
+          LAST_RC_TAG=$(git tag -l "v*.*.*-rc.*" | sort -V | tail -n1 || echo "v1.0.0-rc.1")
           CLEAN_VERSION=$(echo "$LAST_RC_TAG" | sed -E 's/-rc\.[0-9]+//')
           
           echo "VERSION=$CLEAN_VERSION" >> $GITHUB_ENV
-- 
