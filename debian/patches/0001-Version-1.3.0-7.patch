diff --git a/src/utils/CalculateSize.hpp b/src/utils/CalculateSize.hpp
new file mode 100644
index 0000000..2bfe047
--- /dev/null
+++ b/src/utils/CalculateSize.hpp
@@ -0,0 +1,20 @@
+#pragma once
+
+#include <QDirIterator>
+
+/**
+ * @brief Получает общий размер файлов в указанной директории.
+ * Рекомендуется выполнять асинхронно.
+ * 
+ * @param dirPath Путь до папки.
+ * @return quint64 Размер папки.
+ */
+inline quint64 getDirSize(const QString &dirPath) {
+    quint64 size = 0;
+    QDirIterator it(dirPath, QDir::Files | QDir::NoDotAndDotDot, QDirIterator::Subdirectories);
+    while (it.hasNext()) {
+        it.next();
+        size += it.fileInfo().size();
+    }
+    return size;
+}
